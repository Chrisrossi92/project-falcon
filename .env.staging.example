# Falcon AMC staging smoke harness template.
# Copy this file to .env.staging.local or export these variables in your shell.
# Never commit real Supabase keys. Service role keys bypass RLS and are for approved operators only.
# Prepare the disposable rehearsal baseline with:
#   npm run amc:staging:rehearsal:prepare

# Required staging/final-rehearsal target identity.
AMC_STAGING_PROJECT_REF=voompccpkjfcsmehdoqu
AMC_STAGING_SUPABASE_URL=https://voompccpkjfcsmehdoqu.supabase.co

# Required secrets. Fill these from the approved staging Supabase project only.
# Supabase may show these as sb_secret_... and sb_publishable_... values.
AMC_STAGING_SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-or-secret-key>
AMC_STAGING_SUPABASE_ANON_KEY=<staging-anon-or-publishable-key>

# Optional production deny-list. The scripts refuse to run if the target ref appears here.
AMC_PRODUCTION_PROJECT_REFS=okwqhkrsjgxrhyisaovc

# Supported disposable smoke accounts. Fixture scripts and Playwright specs honor these overrides.
AMC_STAGING_SMOKE_OWNER_EMAIL=amc.smoke.owner+staging@example.test
AMC_STAGING_SMOKE_CLIENT_EMAIL=amc.smoke.client+staging@example.test
AMC_STAGING_SMOKE_VENDOR_EMAIL=amc.smoke.vendor+staging@example.test
AMC_STAGING_SMOKE_WRONG_VENDOR_EMAIL=amc.smoke.wrongvendor+staging@example.test
AMC_STAGING_SMOKE_PASSWORD=FalconSmoke123!

# Supported disposable smoke record identifiers.
AMC_STAGING_SMOKE_ORDER_NUMBER=AMC-STAGING-SMOKE-001
# Optional artifact directory. Defaults to RUNNER_TEMP, then TMPDIR, then the OS temp directory.
# AMC_SMOKE_ARTIFACT_DIR=/path/to/project-falcon-amc-smoke

# Opt-in browser smoke. Keep disabled unless running manually.
AMC_STAGING_BROWSER_SMOKE=0
AMC_STAGING_APP_URL=http://localhost:5173
AMC_STAGING_BROWSER_HEADLESS=1
